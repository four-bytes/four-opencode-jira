{
  "name": "@four-bytes/four-opencode-jira",
  "version": "0.3.0",
  "description": "Jira REST API integration tools for opencode agents — 6 custom tools (get_issue, add_comment, transition, extract_key, sync_progress, validate_config), project-local .opencode/jira.json config, optional hook automation. Source: Perplexity P49.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/four-opencode-jira.js",
  "types": "dist/four-opencode-jira.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "keywords": ["opencode", "opencode-plugin", "four-bytes", "jira", "atlassian"],
  "exports": {
    "./server": {
      "types": "./dist/four-opencode-jira.d.ts",
      "import": "./dist/four-opencode-jira.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.jsx"
    }
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.13",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.7.3"
  }
}
